generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     Role
  offers    Offer[]  @relation("CompanyOffers")
  applications Application[]
}

model Offer {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  type        String
  company     User     @relation("CompanyOffers", fields: [companyId], references: [id])
  companyId   Int
  applications Application[]

}

model Application {
  id        Int   @id @default(autoincrement())
  student   User  @relation(fields: [studentId], references: [id])
  studentId Int
  offer     Offer @relation(fields: [offerId], references: [id])
  offerId   Int
  status    String @default("pending")
}
enum Role {
  student
  company
  admin
}